<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:T1"
        x:Class="T1.MainWindow"
        x:DataType="local:MainWindow"
        Title="АРМ Работника Склада"
        Width="960" Height="620"
        MinWidth="700" MinHeight="400"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E">

    <Window.KeyBindings>
        <KeyBinding Gesture="Ctrl+N" Command="{Binding AddProductCommand}"/>
        <KeyBinding Gesture="Ctrl+E" Command="{Binding EditProductCommand}"/>
        <KeyBinding Gesture="Ctrl+D" Command="{Binding DeleteProductCommand}"/>
    </Window.KeyBindings>

    <DockPanel>

        <!-- Главное меню -->
        <Menu DockPanel.Dock="Top" Background="#2D2D2D">
            <MenuItem Header="Файл" Foreground="#DDD">
                <MenuItem Header="Выход" Click="OnExit"/>
            </MenuItem>
            <MenuItem Header="Склад" Foreground="#DDD">
                <MenuItem Header="Добавить товар (Ctrl+N)"  Command="{Binding AddProductCommand}"/>
                <MenuItem Header="Редактировать (Ctrl+E)"   Command="{Binding EditProductCommand}"/>
                <Separator/>
                <MenuItem Header="Удалить товар (Ctrl+D)"   Command="{Binding DeleteProductCommand}"/>
            </MenuItem>
            <MenuItem Header="Настройки" Foreground="#DDD">
                <MenuItem Header="О программе" Click="OnAbout"/>
            </MenuItem>
        </Menu>

        <!-- Панель инструментов -->
        <Border DockPanel.Dock="Top" Background="#2D2D2D"
                Padding="10,7" BorderBrush="#444" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto,*,Auto,16,Auto,16,Auto">

                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6">
                    <Button Content="+ Добавить товар"
                            Command="{Binding AddProductCommand}"
                            Background="#0078D4" Foreground="White"
                            Padding="12,6" CornerRadius="4" ToolTip.Tip="Ctrl+N"/>
                    <Button Content="Редактировать"
                            Command="{Binding EditProductCommand}"
                            Background="#3A3A3A" Foreground="#DDD"
                            Padding="12,6" CornerRadius="4" ToolTip.Tip="Ctrl+E"/>
                    <Button Content="Удалить"
                            Command="{Binding DeleteProductCommand}"
                            Background="#3A3A3A" Foreground="#E07070"
                            Padding="12,6" CornerRadius="4" ToolTip.Tip="Ctrl+D"/>
                </StackPanel>

                <TextBlock Grid.Column="2" x:Name="TotalCountText"
                           Text="Позиций: 0" Foreground="#AAA"
                           FontSize="13" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="4" x:Name="TotalSumText"
                           Text="Сумма: 0 ₽" Foreground="#AAA"
                           FontSize="13" VerticalAlignment="Center"/>

                <StackPanel Grid.Column="6" Orientation="Horizontal" Spacing="8">
                    <ComboBox x:Name="CategoryFilter" Width="160"
                              Background="#3A3A3A" Foreground="White"
                              BorderBrush="#555" Padding="8,4"
                              SelectionChanged="OnFilterChanged">
                        <ComboBoxItem IsSelected="True">Все категории</ComboBoxItem>
                        <ComboBoxItem>Электроника</ComboBoxItem>
                        <ComboBoxItem>Продукты</ComboBoxItem>
                        <ComboBoxItem>Одежда</ComboBoxItem>
                        <ComboBoxItem>Инструменты</ComboBoxItem>
                        <ComboBoxItem>Стройматериалы</ComboBoxItem>
                        <ComboBoxItem>Другое</ComboBoxItem>
                    </ComboBox>
                    <TextBox x:Name="SearchBox" Width="200"
                             PlaceholderText="Поиск..."
                             Background="#3A3A3A" Foreground="White"
                             BorderBrush="#555" Padding="8,5" CornerRadius="4"
                             TextChanged="OnSearchChanged"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Статус-бар -->
        <Border DockPanel.Dock="Bottom" Background="#252525"
                Padding="10,5" BorderBrush="#383838" BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock x:Name="StatusText" Grid.Column="0"
                           Text="Готово" Foreground="#666"
                           FontSize="12" VerticalAlignment="Center"/>
                <TextBlock x:Name="SelectionText" Grid.Column="1"
                           Foreground="#666" FontSize="12" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Таблица товаров -->
        <DataGrid x:Name="ProductGrid"
                  x:DataType="local:ProductViewModel"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  CanUserSortColumns="True"
                  CanUserResizeColumns="True"
                  Background="#1E1E1E"
                  RowBackground="#1E1E1E"
                  Foreground="#DDD"
                  BorderThickness="0"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="#333"
                  FontSize="13">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID"           Binding="{Binding Id}"          Width="55"/>
                <DataGridTextColumn Header="Наименование" Binding="{Binding Name}"        Width="*"/>
                <DataGridTextColumn Header="Категория"    Binding="{Binding Category}"    Width="130"/>
                <DataGridTextColumn Header="Кол-во"       Binding="{Binding Quantity}"    Width="75"/>
                <DataGridTextColumn Header="Ед."          Binding="{Binding Unit}"        Width="55"/>
                <DataGridTextColumn Header="Цена"         Binding="{Binding Price,        StringFormat={}{0:F2} ₽}" Width="105"/>
                <DataGridTextColumn Header="Сумма"        Binding="{Binding TotalValue,   StringFormat={}{0:F2} ₽}" Width="115"/>
                <DataGridTextColumn Header="Описание"     Binding="{Binding Description}" Width="180"/>
            </DataGrid.Columns>
        </DataGrid>

    </DockPanel>
</Window>
