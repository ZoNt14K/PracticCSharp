<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="T1.ProductDialog"
        Title="Товар"
        Width="400" Height="380"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="#1E1E1E">

    <StackPanel Margin="20" Spacing="8">

        <TextBlock x:Name="DialogTitle" Text="Добавить товар"
                   FontSize="16" FontWeight="SemiBold"
                   Foreground="#DDD" Margin="0,0,0,8"/>

        <TextBlock Text="Наименование" Foreground="#888" FontSize="12"/>
        <TextBox x:Name="NameBox" PlaceholderText="Введите название"
                 Background="#2D2D2D" Foreground="White" BorderBrush="#555"/>

        <Grid ColumnDefinitions="*,10,*">
            <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock Text="Категория" Foreground="#888" FontSize="12"/>
                <ComboBox x:Name="CategoryBox" HorizontalAlignment="Stretch"
                          Background="#2D2D2D" Foreground="White" BorderBrush="#555">
                    <ComboBoxItem>Электроника</ComboBoxItem>
                    <ComboBoxItem>Продукты</ComboBoxItem>
                    <ComboBoxItem>Одежда</ComboBoxItem>
                    <ComboBoxItem>Инструменты</ComboBoxItem>
                    <ComboBoxItem>Стройматериалы</ComboBoxItem>
                    <ComboBoxItem>Другое</ComboBoxItem>
                </ComboBox>
            </StackPanel>
            <StackPanel Grid.Column="2" Spacing="4">
                <TextBlock Text="Ед. измерения" Foreground="#888" FontSize="12"/>
                <ComboBox x:Name="UnitBox" HorizontalAlignment="Stretch"
                          Background="#2D2D2D" Foreground="White" BorderBrush="#555">
                    <ComboBoxItem>шт</ComboBoxItem>
                    <ComboBoxItem>кг</ComboBoxItem>
                    <ComboBoxItem>л</ComboBoxItem>
                    <ComboBoxItem>м</ComboBoxItem>
                    <ComboBoxItem>уп</ComboBoxItem>
                </ComboBox>
            </StackPanel>
        </Grid>

        <Grid ColumnDefinitions="*,10,*">
            <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock Text="Количество" Foreground="#888" FontSize="12"/>
                <TextBox x:Name="QuantityBox" PlaceholderText="0"
                         Background="#2D2D2D" Foreground="White" BorderBrush="#555"/>
            </StackPanel>
            <StackPanel Grid.Column="2" Spacing="4">
                <TextBlock Text="Цена (₽)" Foreground="#888" FontSize="12"/>
                <TextBox x:Name="PriceBox" PlaceholderText="0.00"
                         Background="#2D2D2D" Foreground="White" BorderBrush="#555"/>
            </StackPanel>
        </Grid>

        <TextBlock Text="Описание" Foreground="#888" FontSize="12"/>
        <TextBox x:Name="DescriptionBox" PlaceholderText="Необязательно"
                 Height="60" AcceptsReturn="True" TextWrapping="Wrap"
                 Background="#2D2D2D" Foreground="White" BorderBrush="#555"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                    Spacing="8" Margin="0,12,0,0">
            <Button Content="Отмена" Click="OnCancel"
                    Background="#3A3A3A" Foreground="#DDD" Padding="16,7" CornerRadius="4"/>
            <Button Content="Сохранить" Click="OnSave"
                    Background="#0078D4" Foreground="White" Padding="16,7" CornerRadius="4"/>
        </StackPanel>

    </StackPanel>
</Window>
